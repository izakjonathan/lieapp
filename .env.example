# Optional: use Supabase for true multi-device persistence on Vercel/serverless hosts.
# Without these values the app falls back to .data/lie-ledger-games.json on a Node server.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_TABLE=lie_score_games

# Optional local/self-hosted JSON storage path.
# LIE_LEDGER_STORAGE_PATH=.data/lie-ledger-games.json
